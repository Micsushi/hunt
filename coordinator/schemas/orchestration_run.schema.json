{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OrchestrationRun",
  "type": "object",
  "required": [
    "run_id",
    "job_id",
    "status",
    "source_runtime",
    "manual_review_required",
    "manual_review_flags",
    "submit_allowed",
    "started_at",
    "updated_at"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "job_id": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string"
    },
    "source_runtime": {
      "type": "string"
    },
    "browser_lane": {
      "type": [
        "string",
        "null"
      ]
    },
    "job_source": {
      "type": [
        "string",
        "null"
      ]
    },
    "job_title": {
      "type": [
        "string",
        "null"
      ]
    },
    "company": {
      "type": [
        "string",
        "null"
      ]
    },
    "selected_resume_version_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "selected_resume_pdf_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "selected_resume_tex_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "apply_url": {
      "type": [
        "string",
        "null"
      ]
    },
    "ats_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "apply_context_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "c3_apply_context_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "fill_result_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "browser_summary_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "decision_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "final_status_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "manual_review_required": {
      "type": "boolean"
    },
    "manual_review_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "manual_review_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "submit_allowed": {
      "type": "boolean"
    },
    "submit_approval_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "started_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "completed_at": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false
}
