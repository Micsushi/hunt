# Hunt server deploy environment template
# Copy to `.env.server2` on the target host or let Ansible render that file.

HUNT_DOCKER_NETWORK_NAME=homelab

HUNT_POSTGRES_USER=hunt
HUNT_POSTGRES_PASSWORD=replace-me
HUNT_POSTGRES_DB=hunt
HUNT_POSTGRES_CONTAINER_NAME=hunt_postgres
HUNT_POSTGRES_STORAGE=/home/michael/data/hunt/postgres
HUNT_POSTGRES_BIND_HOST=127.0.0.1
HUNT_POSTGRES_HOST_PORT=5432

HUNT_COMPOSE_DB_URL=postgresql://hunt:replace-me@hunt_postgres:5432/hunt
HUNT_SERVICE_TOKEN=replace-me
HUNT_CREDENTIAL_KEY=replace-me
HUNT_ADMIN_USERNAME=admin
HUNT_ADMIN_PASSWORD=replace-me

HUNT_REVIEW_CONTAINER_NAME=hunt_review
HUNT_BACKEND_CONTAINER_NAME=hunt_backend
HUNT_FRONTEND_CONTAINER_NAME=hunt_frontend
HUNT_HUNTER_CONTAINER_NAME=hunt_hunter
HUNT_HUNTER_SCHEDULER_CONTAINER_NAME=hunt_hunter_scheduler
HUNT_FLETCHER_CONTAINER_NAME=hunt_fletcher
HUNT_COORDINATOR_CONTAINER_NAME=hunt_coordinator

HUNT_HUNTER_URL=http://hunt_hunter:8001
HUNT_FLETCHER_URL=http://hunt_fletcher:8002
HUNT_COORDINATOR_URL=http://hunt_coordinator:8003

HUNT_REVIEW_BIND_HOST=127.0.0.1
HUNT_REVIEW_HOST_PORT=18080
HUNT_HUNTER_BIND_HOST=127.0.0.1
HUNT_HUNTER_HOST_PORT=18001
HUNT_FLETCHER_BIND_HOST=127.0.0.1
HUNT_FLETCHER_HOST_PORT=18002
HUNT_COORDINATOR_BIND_HOST=127.0.0.1
HUNT_COORDINATOR_HOST_PORT=18003
HUNT_FRONTEND_BIND_HOST=127.0.0.1
HUNT_FRONTEND_HOST_PORT=18090

HUNT_ARTIFACTS_STORAGE=/home/michael/data/hunt/artifacts
HUNT_RESUME_STORAGE=/home/michael/data/hunt/resumes
HUNT_COORDINATOR_STORAGE=/home/michael/data/hunt/coordinator
HUNT_STATE_STORAGE=/home/michael/hunt/.state

LINKEDIN_BROWSER_CHANNEL=chromium
ENRICHMENT_BATCH_LIMIT=25
ENRICHMENT_TIMEOUT_MS=45000
ENRICHMENT_SLOW_MO_MS=0
ENRICHMENT_UI_VERIFY_BLOCKED=false
RUN_INTERVAL_SECONDS=600

HUNT_RESUME_MODEL_BACKEND=ollama
HUNT_OLLAMA_HOST=http://host.docker.internal:11434
HUNT_OLLAMA_MODEL=qwen3:8b
HUNT_OLLAMA_TIMEOUT_SEC=120
