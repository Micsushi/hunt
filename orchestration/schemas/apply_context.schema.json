{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ApplyContext",
  "type": "object",
  "required": [
    "job_id",
    "source_mode",
    "concern_flags",
    "created_at"
  ],
  "properties": {
    "job_id": {
      "type": "integer",
      "minimum": 1
    },
    "title": {
      "type": [
        "string",
        "null"
      ]
    },
    "company": {
      "type": [
        "string",
        "null"
      ]
    },
    "apply_url": {
      "type": [
        "string",
        "null"
      ]
    },
    "job_url": {
      "type": [
        "string",
        "null"
      ]
    },
    "source": {
      "type": [
        "string",
        "null"
      ]
    },
    "ats_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "apply_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "auto_apply_eligible": {
      "type": "boolean"
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "selected_resume_version_id": {
      "type": [
        "integer",
        "string",
        "null"
      ]
    },
    "selected_resume_pdf_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "selected_resume_tex_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "selected_resume_summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "selected_resume_ready_for_c3": {
      "type": "boolean"
    },
    "job_description_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_mode": {
      "type": "string"
    },
    "concern_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "apply_context_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
