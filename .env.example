# Hunt local/dev environment (copy to `.env` and fill in real values)
#
# Notes:
# - `.env` is optional; env vars still win when set by systemd/Ansible/Docker.
# - Keep secrets out of git; put them only in your local `.env`.
# - On server2 the systemd unit sets most of these; only override what differs.

# ---- Database ----
# Leave HUNT_DB_URL blank to use SQLite (local dev default).
# Set to a Postgres URL for production (server2):
# HUNT_DB_URL=postgresql://hunt:password@localhost:5432/hunt
#
# ---- Core paths ----
# HUNT_DB_PATH=C:\Users\sushi\Documents\Github\hunt\hunt.db
# HUNT_ARTIFACTS_DIR=C:\Users\sushi\Documents\Github\hunt\runtime\artifacts
# HUNT_RESUME_ARTIFACTS_DIR=C:\Users\sushi\Documents\Github\hunt\runtime\resumes
#
# ---- Credential encryption ----
# Required for linkedin_accounts.password_encrypted.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# HUNT_CREDENTIAL_KEY=

# ---- C2 (Fletcher) model backend ----
# heuristic = fast local rules only (good for tests)
# ollama    = use local Ollama to refine classification + keywords
HUNT_RESUME_MODEL_BACKEND=ollama
HUNT_RESUME_MODEL_NAME=deterministic-stage1

# ---- Ollama (local LLM) ----
# Pull once: ollama pull gemma2:9b   (or gemma2:2b / gemma3:4b etc., then set HUNT_OLLAMA_MODEL to match)
HUNT_OLLAMA_HOST=http://127.0.0.1:11434
HUNT_OLLAMA_MODEL=gemma2:9b
HUNT_OLLAMA_TIMEOUT_SEC=120

# ---- C2 LLM I/O logging ----
# Write the full Ollama prompt and response to the attempt directory.
# On by default (1). Disable with 0 to save disk on high-volume runs.
HUNT_RESUME_LOG_LLM_IO=1
# Max characters to capture from prompt/response (default 120 000).
# HUNT_RESUME_LOG_LLM_MAX_CHARS=120000

# ---- C2 candidate profile + bullet library ----
# Paths to your personal profile and bullet library files.
# Defaults: fletcher/candidate_profile.md and fletcher/bullet_library.md (gitignored).
# Copy from fletcher/templates/candidate_profile.template.md to get started.
# HUNT_CANDIDATE_PROFILE_PATH=fletcher/candidate_profile.md
# HUNT_BULLET_LIBRARY_PATH=fletcher/bullet_library.md

# ---- Review app ops token (optional) ----
# REVIEW_OPS_TOKEN=

# ---- C1 enrichment knobs (optional overrides) ----
# ENRICHMENT_BATCH_LIMIT=25
# ENRICHMENT_TIMEOUT_MS=45000
# ENRICHMENT_UI_VERIFY_BLOCKED=false

