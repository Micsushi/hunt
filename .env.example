# Hunt local/dev environment (copy to `.env` and fill in real values)
#
# Notes:
# - `.env` is optional; env vars still win when set by systemd/Ansible/Docker.
# - Keep secrets out of git; put them only in your local `.env`.
#
# ---- Core paths ----
# HUNT_DB_PATH=C:\Users\sushi\Documents\Github\hunt\hunt.db
# HUNT_ARTIFACTS_DIR=C:\Users\sushi\Documents\Github\hunt\runtime\artifacts
# HUNT_RESUME_ARTIFACTS_DIR=C:\Users\sushi\Documents\Github\hunt\runtime\resumes

# ---- C2 (Fletcher) model backend ----
# heuristic | ollama
HUNT_RESUME_MODEL_BACKEND=ollama
HUNT_RESUME_MODEL_NAME=deterministic-stage1

# Ollama (local)
HUNT_OLLAMA_HOST=http://127.0.0.1:11434
HUNT_OLLAMA_MODEL=qwen3.5:9b
HUNT_OLLAMA_TIMEOUT_SEC=120

# ---- Review app ops token (optional) ----
# REVIEW_OPS_TOKEN=

# ---- C1 enrichment knobs (optional overrides) ----
# ENRICHMENT_BATCH_LIMIT=25
# ENRICHMENT_TIMEOUT_MS=45000
# ENRICHMENT_UI_VERIFY_BLOCKED=false

