# Hunt local/dev environment (copy to `.env` and fill in real values)
#
# Notes:
# - `.env` is optional; env vars still win when set by systemd/Ansible/Docker.
# - Keep secrets out of git; put them only in your local `.env`.
# - On server2 the systemd unit sets most of these; only override what differs.

# ---- Database ----
# Leave HUNT_DB_URL blank to use SQLite (local dev default).
# Set to a Postgres URL for production (server2):
# HUNT_DB_URL=postgresql://hunt:password@localhost:5432/hunt
#
# ---- Core paths ----
# HUNT_DB_PATH=C:\Users\sushi\Documents\Github\hunt\hunt.db
# HUNT_ARTIFACTS_DIR=C:\Users\sushi\Documents\Github\hunt\runtime\artifacts
# HUNT_RESUME_ARTIFACTS_DIR=C:\Users\sushi\Documents\Github\hunt\runtime\resumes
#
# ---- Credential encryption ----
# Required for linkedin_accounts.password_encrypted.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# HUNT_CREDENTIAL_KEY=

# ---- Service auth + URLs ----
# Shared bearer token for C0 → C1/C2/C4 service calls. Leave blank to disable auth in dev.
# HUNT_SERVICE_TOKEN=
# Service base URLs (defaults shown — override in production).
# HUNT_HUNTER_URL=http://localhost:8001
# HUNT_FLETCHER_URL=http://localhost:8002
# HUNT_COORDINATOR_URL=http://localhost:8003

# ---- C2 (Fletcher) model backend ----
# heuristic = fast local rules only (good for tests)
# ollama    = use local Ollama to refine classification + keywords
HUNT_RESUME_MODEL_BACKEND=ollama
HUNT_RESUME_MODEL_NAME=deterministic-stage1

# ---- Ollama (local LLM) ----
# Pull once: ollama pull gemma4:e4b   (then set HUNT_OLLAMA_MODEL to match)
HUNT_OLLAMA_HOST=http://127.0.0.1:11434
HUNT_OLLAMA_MODEL=gemma4:e4b
HUNT_OLLAMA_TIMEOUT_SEC=120

# ---- C2 LLM I/O logging ----
# Write the full Ollama prompt and response to the attempt directory.
# On by default (1). Disable with 0 to save disk on high-volume runs.
HUNT_RESUME_LOG_LLM_IO=1
# Max characters to capture from prompt/response (default 120 000).
# HUNT_RESUME_LOG_LLM_MAX_CHARS=120000

# ---- C2 candidate profile + bullet library ----
# Paths to your personal profile and bullet library files.
# Defaults: fletcher/candidate_profile.md and fletcher/bullet_library.md (gitignored).
# Copy from fletcher/templates/candidate_profile.template.md to get started.
# HUNT_CANDIDATE_PROFILE_PATH=fletcher/candidate_profile.md
# HUNT_BULLET_LIBRARY_PATH=fletcher/bullet_library.md

# ---- Local Docker deploy: persistent state + data directories ----
# Default: .hunt-state/ and .hunt-data/ at the repo root (gitignored).
# Set to absolute paths if you want data outside the repo.
# HUNT_LOCAL_STATE_DIR=C:\Users\sushi\hunt-state
# HUNT_LOCAL_DATA_DIR=C:\Users\sushi\hunt-data
#
# auth-save writes to: <HUNT_LOCAL_STATE_DIR>/linkedin_auth_state.json
# The hunter container reads it from /app/.state/linkedin_auth_state.json

# ---- Discord notifications (optional) ----
# Webhook URL for operational alerts (LinkedIn auth expired, C4 approval pending, run failed, etc.)
# HUNT_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ---- Review app ops token (optional) ----
# REVIEW_OPS_TOKEN=

# ---- C3 email verification + Workday smoke ----
# Used by scripts/c3_mail_verify_bridge.js and scripts/c3_email_verification_smoke.js.
# Keep real mailbox/app-password values only in local `.env`.
#
# fake = local fixture smoke, imap = real mailbox verification.
# HUNT_C3_MAIL_PROVIDER=fake
#
# Gmail app-password IMAP example:
# HUNT_C3_MAIL_PROVIDER=imap
# HUNT_C3_MAIL_EMAIL=your.throwaway.gmail@gmail.com
# HUNT_C3_MAIL_PASSWORD=your-16-character-gmail-app-password
# HUNT_C3_MAIL_IMAP_HOST=imap.gmail.com
# HUNT_C3_MAIL_IMAP_PORT=993
# HUNT_C3_MAIL_IMAP_SECURE=true
#
# Gmail defaults to [Gmail]/All Mail in the bridge because some Workday tenant
# verification messages do not appear through plain INBOX. Override only if needed.
# HUNT_C3_MAIL_IMAP_MAILBOX=[Gmail]/All Mail
#
# Local bridge used by the C3 extension background message
# hunt.apply.await_email_verification.
# HUNT_C3_MAIL_BRIDGE_PORT=8765
# HUNT_C3_MAIL_MAX_WAIT_SECONDS=90
#
# Optional safety allowlists. Link hosts are also derived from the Workday URL.
# UBC Workday sent from noreply@workday.svc.ubc.ca while linking to
# ubc.wd10.myworkdayjobs.com, so tenant sender domains can differ from link hosts.
# HUNT_C3_MAIL_FROM_ALLOWLIST=workday.com,myworkday.com,myworkdayjobs.com
# HUNT_C3_MAIL_LINK_HOST_ALLOWLIST=workday.com,myworkday.com,myworkdayjobs.com
#
# Real Workday smoke URL and account credentials used for signup/login fields.
# Prefer a throwaway mailbox/account. The script stops before final application submit.
# HUNT_C3_TEST_WORKDAY_URL=https://tenant.wd10.myworkdayjobs.com/site/job/.../apply?source=LinkedIn
# HUNT_C3_TEST_ACCOUNT_EMAIL=your.throwaway.gmail@gmail.com
# HUNT_C3_TEST_ACCOUNT_PASSWORD=StrongUniquePassword!23
#
# Fresh logged-out Workday account bootstrap + application walk:
# node scripts\c3_workday_fresh_apply_smoke.js --provider imap --cdp-port 9222 --reset-site-data

# ---- C1 enrichment knobs (optional overrides) ----
# ENRICHMENT_BATCH_LIMIT=25
# ENRICHMENT_TIMEOUT_MS=45000
# ENRICHMENT_UI_VERIFY_BLOCKED=false
# ENRICHMENT_ALERT_MIN_ATTEMPTS=5
# ENRICHMENT_ALERT_FAILURE_RATE_PERCENT=50
# ENRICHMENT_ALERT_COOLDOWN_MINUTES=60
