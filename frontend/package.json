{
  "name": "hunt-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "vite:raw": "vite",
    "dev": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ../scripts/dev-mode.ps1 full",
    "dev:ui": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ../scripts/dev-mode.ps1 ui",
    "dev:c0": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ../scripts/dev-mode.ps1 c0",
    "dev:c1": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ../scripts/dev-mode.ps1 c1",
    "dev:c2": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ../scripts/dev-mode.ps1 c2",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^3.8.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.59.0",
    "vite": "^6.0.5"
  }
}
