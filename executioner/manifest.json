{
  "manifest_version": 3,
  "name": "Hunt Apply Extension",
  "version": "0.1.0",
  "description": "C3 (Executioner) Chrome extension scaffold for Workday autofill.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "activeTab",
    "alarms",
    "downloads",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Hunt Apply"
  },
  "options_page": "src/options/options.html",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/bootstrap.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
