FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

COPY hunter/requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

COPY coordinator /app/coordinator
COPY fletcher /app/fletcher
COPY hunter /app/hunter

EXPOSE 8003

CMD ["python", "-m", "uvicorn", "coordinator.service_api:app", "--host", "0.0.0.0", "--port", "8003"]
